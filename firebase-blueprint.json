{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "admin"] },
        "first_name": { "type": "string" },
        "father_name": { "type": "string" },
        "grandfather_name": { "type": "string" },
        "family_name": { "type": "string" },
        "school_name": { "type": "string" },
        "grade": { "type": "string" }
      },
      "required": ["uid", "role", "first_name", "father_name"]
    },
    "Path": {
      "title": "Path",
      "description": "Learning path",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "category": { "type": "string" },
        "image_url": { "type": "string" },
        "order_index": { "type": "integer" }
      },
      "required": ["title"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "Lesson within a path",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "image_url": { "type": "string" },
        "source": { "type": "string" },
        "duration": { "type": "string" },
        "order_index": { "type": "integer" }
      },
      "required": ["title"]
    },
    "Page": {
      "title": "Page",
      "description": "Page within a lesson",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["explanation", "question", "media", "matching", "blanks", "iframe"] },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "image_url": { "type": "string" },
        "video_url": { "type": "string" },
        "audio_url": { "type": "string" },
        "question": { "type": "string" },
        "option_a": { "type": "string" },
        "option_b": { "type": "string" },
        "option_c": { "type": "string" },
        "option_d": { "type": "string" },
        "correct_option": { "type": "string" },
        "explanation": { "type": "string" },
        "order_index": { "type": "integer" }
      },
      "required": ["type", "order_index"]
    },
    "Progress": {
      "title": "Progress",
      "description": "User progress on a lesson",
      "type": "object",
      "properties": {
        "lesson_id": { "type": "string" },
        "completed": { "type": "boolean" },
        "correct_answers": { "type": "integer" },
        "total_questions": { "type": "integer" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["lesson_id", "completed"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or personal notification",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["general", "personal", "category"] },
        "target_user_id": { "type": "string" },
        "target_category": { "type": "string" },
        "path_id": { "type": "string" },
        "lesson_id": { "type": "string" },
        "sender_id": { "type": "string" },
        "sender_name": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "read_by": { "type": "array" },
        "read": { "type": "boolean" }
      },
      "required": ["title", "message", "type", "sender_id"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/paths/{pathId}": {
      "schema": "Path",
      "description": "Learning paths"
    },
    "/paths/{pathId}/lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "Lessons in a path"
    },
    "/paths/{pathId}/lessons/{lessonId}/pages/{pageId}": {
      "schema": "Page",
      "description": "Pages in a lesson"
    },
    "/users/{userId}/progress/{lessonId}": {
      "schema": "Progress",
      "description": "User progress tracking"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "System notifications"
    }
  }
}
